# Copy file nay thanh .env.local va dien values

# Google OAuth Client ID (lay tu Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API URL
VITE_API_URL=http://localhost:3000

# Public site URL (for previewing news articles)
VITE_PUBLIC_SITE_URL=http://localhost:3001
