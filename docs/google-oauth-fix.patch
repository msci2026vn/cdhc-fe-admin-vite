## File: /home/cdhc/apps/cdhc-be/src/modules/auth/google-auth.ts

### FIX: Add Timeout for JWKS Fetch

Add this after line 92 (after `getGoogleJWKS()` function):

```typescript
// Add timeout wrapper for JWKS fetch
async function verifyIdTokenWithTimeout(
  idToken: string,
  timeoutMs: number = 10000
): Promise<jose.JWTPayload & { sub: string; email: string }> {
  const clientIds = getGoogleClientIds();

  // Race between JWT verification and timeout
  const result = await Promise.race([
    jose.jwtVerify(idToken, getGoogleJWKS(), {
      issuer: GOOGLE_ISSUERS,
      audience: clientIds,
    }),
    new Promise<never>((_, reject) =>
      setTimeout(() => reject(new Error('Google JWKS fetch timeout')), timeoutMs)
    ),
  ]);

  return result.payload as jose.JWTPayload & { sub: string; email: string };
}

// Replace the existing verifyGoogleIdToken function
export async function verifyGoogleIdToken(idToken: string): Promise<GoogleUserPayload> {
  // Validate input
  if (!idToken || typeof idToken !== 'string') {
    throw new GoogleAuthError('MISSING_TOKEN', 'ID Token is required');
  }

  try {
    // Use timeout wrapper
    const payload = await verifyIdTokenWithTimeout(idToken, 10000); // 10 second timeout

    // Extract and validate required fields
    const sub = payload.sub;
    const email = payload.email as string | undefined;

    if (!sub) {
      throw new GoogleAuthError('INVALID_TOKEN', 'Token missing subject (sub) claim');
    }

    if (!email) {
      throw new GoogleAuthError('INVALID_TOKEN', 'Token missing email claim');
    }

    // Build user payload
    const userPayload: GoogleUserPayload = {
      sub,
      email,
      emailVerified: (payload.email_verified as boolean) ?? false,
      name: (payload.name as string) ?? email.split('@')[0],
      picture: (payload.picture as string) ?? '',
      givenName: payload.given_name as string | undefined,
      familyName: payload.family_name as string | undefined,
      locale: payload.locale as string | undefined,
    };

    return userPayload;
  } catch (error) {
    // Handle jose errors
    if (error instanceof jose.errors.JWTExpired) {
      throw new GoogleAuthError('TOKEN_EXPIRED', 'Google ID Token has expired');
    }

    if (error instanceof jose.errors.JWTClaimValidationFailed) {
      const claim = (error as jose.errors.JWTClaimValidationFailed).claim;

      if (claim === 'aud') {
        throw new GoogleAuthError('INVALID_AUDIENCE', 'Token was not issued for this application', {
          expectedAudiences: getGoogleClientIds(),
        });
      }

      if (claim === 'iss') {
        throw new GoogleAuthError('INVALID_ISSUER', 'Token was not issued by Google', {
          expectedIssuers: GOOGLE_ISSUERS,
        });
      }
    }

    if (error instanceof jose.errors.JWSSignatureVerificationFailed) {
      throw new GoogleAuthError('INVALID_TOKEN', 'Token signature verification failed');
    }

    // Handle timeout
    if (error instanceof Error && error.message === 'Google JWKS fetch timeout') {
      throw new GoogleAuthError('GOOGLE_VERIFICATION_FAILED', 'Cannot reach Google servers. Please try again.');
    }

    // Re-throw GoogleAuthError
    if (error instanceof GoogleAuthError) {
      throw error;
    }

    // Unknown error
    throw new GoogleAuthError('GOOGLE_VERIFICATION_FAILED', 'Failed to verify Google ID Token', {
      originalError: String(error),
    });
  }
}
