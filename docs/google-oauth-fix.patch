### FIX: Add Global Error Handler

Add this after line 130 (after `app.route('/api/auth', ...)`):

```typescript
// Global error handler
app.onError((err, c) => {
  console.error('[GLOBAL ERROR]', {
    error: err,
    message: err.message,
    stack: err.stack,
    path: c.req.path,
    method: c.req.method,
  });

  // Handle GoogleAuthError
  if (err instanceof GoogleAuthError) {
    return c.json(
      {
        success: false,
        error: {
          code: err.code,
          message: err.message,
        },
      },
      err.statusCode || 500,
    );
  }

  // Handle ZodError (validation errors)
  if (err instanceof ZodError) {
    return c.json(
      {
        success: false,
        error: {
          code: 'VALIDATION_ERROR',
          message: 'Dữ liệu không hợp lệ',
          details: err.errors,
        },
      },
      400,
    );
  }

  // Generic error
  const isDev = process.env.NODE_ENV === 'development';

  return c.json(
    {
      success: false,
      error: {
        code: 'INTERNAL_ERROR',
        message: 'Có lỗi xảy ra. Vui lòng thử lại.',
        ...(isDev && {
          details: err.message,
          stack: err.stack,
        }),
      },
    },
    500,
  );
});
